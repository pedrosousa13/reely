{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "types": ["node"],
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "paths": {
      "@storybook/react-vite": [
        "./node_modules/@storybook/react-vite/dist/index.d.ts"
      ]
    }
  },
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/provider-native" },
    { "path": "../../packages/react" }
  ],
  "include": [
    ".storybook",
    "src",
    "vitest.config.ts",
    "../../packages/react/src/**/*.stories.tsx",
    "../../packages/react/test/fixtures/fake-provider.ts"
  ]
}
